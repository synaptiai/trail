{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trail",
  "version": "0.1.0-rc.7",
  "identifier": "ai.synapti.trail",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @trail/ui dev",
    "beforeBuildCommand": "pnpm --filter @trail/ui build"
  },
  "app": {
    "windows": [
      {
        "title": "Trail",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "fullscreen": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "deb", "appimage", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI-native change-control for AI-assisted PRs",
    "longDescription": "Trail captures, redacts, and reviews AI-assisted code changes as auditable packets. Apache-2.0.",
    "publisher": "Synapti AI",
    "homepage": "https://github.com/synaptiai/trail",
    "license": "Apache-2.0",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
