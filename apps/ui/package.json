{
  "name": "@trail/ui",
  "version": "0.1.3",
  "description": "Trail Layer 3: Tauri 2.x + React + Vite desktop application. Three personas (Creator/Reviewer/Auditor) of the Trail v0.1 OSS MLP.",
  "license": "Apache-2.0",
  "author": "Synapti AI",
  "homepage": "https://github.com/synaptiai/trail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synaptiai/trail.git",
    "directory": "apps/ui"
  },
  "bugs": {
    "url": "https://github.com/synaptiai/trail/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "tokens:gen": "node ./scripts/codegen-tokens.mjs",
    "predev": "pnpm run tokens:gen",
    "prebuild": "pnpm run tokens:gen",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx && node ./scripts/lint-css-tokens.mjs",
    "lint:css-tokens": "node ./scripts/lint-css-tokens.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "storybook:test": "test-storybook",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "^1.22.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/test-runner": "^0.19.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitejs/plugin-react": "^4.3.0",
    "axe-core": "^4.10.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fast-check": "^3.22.0",
    "happy-dom": "^20.8.9",
    "jest-axe": "^9.0.0",
    "storybook": "^8.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
